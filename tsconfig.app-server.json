{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "useUnknownInCatchVariables": false,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "plugins/ox/scripts/lib/app-server.mjs",
    "plugins/ox/scripts/lib/codex.mjs",
    "plugins/ox/scripts/lib/fs.mjs",
    "plugins/ox/scripts/lib/process.mjs",
    "plugins/ox/scripts/lib/app-server-protocol.d.ts",
    "plugins/ox/.generated/app-server-types/**/*.ts"
  ]
}
